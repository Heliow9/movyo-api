# URL da API usada pelo app Movyo Garçom.
# Em desenvolvimento local, use por exemplo: http://SEU_IP_DA_REDE:10000
EXPO_PUBLIC_API_URL=https://api.movyo.delivery

# MySQL DATETIME operacional da Movyo (Brasil)
MYSQL_TIMEZONE=-03:00
MOVYO_TZ_OFFSET_MINUTES=-180

# Web Push do Movyo Hub (PWA iOS/Android/Desktop)
# Gere uma única vez com: npm run push:generate-keys
WEB_PUSH_SUBJECT=mailto:suporte@movyo.delivery
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_TTL_SECONDS=120
WEB_PUSH_MAX_FAILURES=5
WEB_PUSH_DEDUP_TTL_MS=20000
GOOGLE_MAPS_API_KEY=
GOOGLE_DIRECTIONS_API_KEY=
GOOGLE_GEOCODING_API_KEY=

# 99Food / Open Delivery
# Use a URL pública para que a tela de status exiba o webhook completo.
PUBLIC_API_BASE_URL=https://api.movyo.delivery
# Quando true, exige token de webhook mesmo para restaurantes que ainda não configuraram token.
FOOD99_REQUIRE_WEBHOOK_TOKEN=false
# Defina true se o payload recebido da 99Food/Open Delivery enviar valores monetários em centavos.
FOOD99_VALUES_IN_CENTS=false
