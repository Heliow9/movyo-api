PORT=10000
MYSQL_HOST=seu-host-mysql
MYSQL_PORT=3306
MYSQL_DATABASE=movyo
MYSQL_USER=seu_usuario
MYSQL_PASSWORD=troque_esta_senha
MYSQL_CONNECTION_LIMIT=10
JWT_SECRET=troque_esta_chave_em_producao

# MySQL DATETIME operacional da Movyo (Brasil)
MYSQL_TIMEZONE=-03:00
MOVYO_TZ_OFFSET_MINUTES=-180

# Integrações/segurança (preencha apenas no .env real do servidor)
PAGARME_SECRET_KEY=
SAAS_ADMIN_INICIAL_EMAIL=
SAAS_ADMIN_INICIAL_SENHA=

# Web Push do Movyo Hub (PWA instalado na Tela de Início)
# Gere uma única vez com: npm run push:generate-keys
WEB_PUSH_SUBJECT=mailto:suporte@movyo.delivery
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_TTL_SECONDS=120
WEB_PUSH_MAX_FAILURES=5
WEB_PUSH_DEDUP_TTL_MS=20000
